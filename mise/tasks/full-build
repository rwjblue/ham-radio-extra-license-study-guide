#!/usr/bin/env bash
#MISE description="Extract/build all text/book outputs and audio scripts; optionally render/verify audio"
#MISE depends=["build-static", "build-qa", "build-prose-if-enabled", "audio-script-auto", "audio-script-qa"]
#MISE outputs={auto=true}
#USAGE flag "--include-audio" help="Also run audio-render and audio-verify"
set -euo pipefail

if [ -z "${usage_include_audio:-}" ]; then
  echo "full-build complete (audio rendering skipped; pass --include-audio to enable)"
  exit 0
fi

provider="${TTS_PROVIDER:-}"

if [ -n "${provider}" ]; then
  if [ "${provider}" = "openai" ]; then
    key_var_name="OPENAI_API_KEY"
    key_value="${OPENAI_API_KEY:-}"
  else
    key_var_name="ELEVENLABS_API_KEY"
    key_value="${ELEVENLABS_API_KEY:-}"
  fi
else
  if [ -n "${ELEVENLABS_API_KEY:-}" ]; then
    key_var_name="ELEVENLABS_API_KEY"
    key_value="${ELEVENLABS_API_KEY:-}"
  else
    key_var_name="OPENAI_API_KEY"
    key_value="${OPENAI_API_KEY:-}"
  fi
fi

if [ -n "${key_value}" ]; then
  mise run audio-render
  mise run audio-verify
else
  provider_label="${provider:-auto}"
  echo "${key_var_name} not set for TTS_PROVIDER=${provider_label}; skipping audio-render and audio-verify"
fi

echo "full-build complete"
