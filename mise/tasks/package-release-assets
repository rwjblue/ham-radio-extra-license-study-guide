#!/usr/bin/env bash
#MISE description="Package pool JSON files with required image assets for release"
#MISE depends=["deps-dev"]
#MISE sources=["dist/pool/extra_pool.json", "dist/pool/extra_pool_prose.json", "dist/pool/assets/**"]
#MISE outputs={auto=true}
set -euo pipefail

release_dir="${RELEASE_DIR:-dist/release}"
mkdir -p "${release_dir}"

bundle_pool_json() {
  local json_name="$1"
  local bundle_name="$2"
  local json_path="dist/pool/${json_name}"
  local json_dir
  local json_file
  local assets_dir

  if [ ! -f "${json_path}" ]; then
    echo "${json_path} not found; skipping ${bundle_name}"
    return 0
  fi

  json_dir="$(dirname "${json_path}")"
  json_file="$(basename "${json_path}")"
  assets_dir="${json_dir}/assets"

  if [ ! -d "${assets_dir}" ]; then
    echo "${assets_dir} not found; skipping ${bundle_name}"
    return 0
  fi

  tar -C "${json_dir}" -czf "${release_dir}/${bundle_name}" "${json_file}" assets
  sha256sum "${release_dir}/${bundle_name}" > "${release_dir}/${bundle_name}.sha256"
  echo "Created ${release_dir}/${bundle_name}"
}

bundle_pool_json "extra_pool.json" "extra_pool_with_assets.tar.gz"
bundle_pool_json "extra_pool_prose.json" "extra_pool_prose_with_assets.tar.gz"
