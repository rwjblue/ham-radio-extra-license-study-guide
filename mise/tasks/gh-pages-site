#!/usr/bin/env bash
#MISE description="Build GitHub Pages site payload from existing dist artifacts"
#MISE depends=["deps-dev"]
#MISE sources=["dist/pool/extra_pool.json", "dist/pool/extra_pool_prose.json", "dist/pool/assets/**", "dist/static/facts.txt", "dist/static/facts.pdf", "dist/static/facts-dark.pdf", "dist/static/facts.epub", "dist/qa/qa.txt", "dist/qa/qa.pdf", "dist/qa/qa-dark.pdf", "dist/qa/qa.epub", "dist/augmented/facts.txt", "dist/augmented/facts.pdf", "dist/augmented/facts-dark.pdf", "dist/augmented/facts.epub", "dist/augmented/qa.txt", "dist/augmented/qa.pdf", "dist/augmented/qa-dark.pdf", "dist/augmented/qa.epub", "dist/audio/fact/script.txt", "dist/audio/fact/manifest.json", "dist/audio/qa/script.txt", "dist/audio/qa/manifest.json", "dist/audio/fact/book.mp3", "dist/audio/qa/book.mp3"]
# Audio book files (mp3) and augmented artifacts are optional; placeholders are created as needed.
#MISE outputs={auto=true}
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
dist_dir="${DIST_DIR:-${repo_root}/dist}"
out_dir="${PAGES_DIR:-${repo_root}/docs}"

required_files=(
  "${dist_dir}/pool/extra_pool.json"
  "${dist_dir}/static/facts.txt"
  "${dist_dir}/static/facts.pdf"
  "${dist_dir}/static/facts-dark.pdf"
  "${dist_dir}/static/facts.epub"
  "${dist_dir}/qa/qa.txt"
  "${dist_dir}/qa/qa.pdf"
  "${dist_dir}/qa/qa-dark.pdf"
  "${dist_dir}/qa/qa.epub"
  "${dist_dir}/audio/fact/script.txt"
  "${dist_dir}/audio/fact/manifest.json"
  "${dist_dir}/audio/qa/script.txt"
  "${dist_dir}/audio/qa/manifest.json"
)

for file in "${required_files[@]}"; do
  if [ ! -f "${file}" ]; then
    echo "Missing required file: ${file}" >&2
    exit 1
  fi
done

pool_json="${dist_dir}/pool/extra_pool.json"
assets_dir="$(dirname "${pool_json}")/assets"
if [ ! -d "${assets_dir}" ]; then
  echo "Missing required assets directory next to JSON: ${assets_dir}" >&2
  exit 1
fi

rm -rf "${out_dir}"
mkdir -p \
  "${out_dir}/pool" \
  "${out_dir}/static" \
  "${out_dir}/qa" \
  "${out_dir}/audio/fact" \
  "${out_dir}/audio/qa"

cp "${pool_json}" "${out_dir}/pool/extra_pool.json"
if [ -f "${dist_dir}/pool/extra_pool_prose.json" ]; then
  cp "${dist_dir}/pool/extra_pool_prose.json" "${out_dir}/pool/extra_pool_prose.json"
fi
cp -R "${assets_dir}" "${out_dir}/pool/assets"

cp "${dist_dir}/static/facts.txt" "${out_dir}/static/facts.txt"
cp "${dist_dir}/static/facts.pdf" "${out_dir}/static/facts.pdf"
cp "${dist_dir}/static/facts-dark.pdf" "${out_dir}/static/facts-dark.pdf"
cp "${dist_dir}/static/facts.epub" "${out_dir}/static/facts.epub"
cp "${dist_dir}/static/facts.txt" "${out_dir}/amateur-extra-license-prep-facts.txt"
cp "${dist_dir}/static/facts.pdf" "${out_dir}/amateur-extra-license-prep-facts.pdf"
cp "${dist_dir}/static/facts-dark.pdf" "${out_dir}/amateur-extra-license-prep-facts-dark.pdf"
cp "${dist_dir}/static/facts.epub" "${out_dir}/amateur-extra-license-prep-facts.epub"

cp "${dist_dir}/qa/qa.txt" "${out_dir}/qa/qa.txt"
cp "${dist_dir}/qa/qa.pdf" "${out_dir}/qa/qa.pdf"
cp "${dist_dir}/qa/qa-dark.pdf" "${out_dir}/qa/qa-dark.pdf"
cp "${dist_dir}/qa/qa.epub" "${out_dir}/qa/qa.epub"
cp "${dist_dir}/qa/qa.txt" "${out_dir}/amateur-extra-license-prep-qa.txt"
cp "${dist_dir}/qa/qa.pdf" "${out_dir}/amateur-extra-license-prep-qa.pdf"
cp "${dist_dir}/qa/qa-dark.pdf" "${out_dir}/amateur-extra-license-prep-qa-dark.pdf"
cp "${dist_dir}/qa/qa.epub" "${out_dir}/amateur-extra-license-prep-qa.epub"

if [ -d "${dist_dir}/augmented" ]; then
  mkdir -p "${out_dir}/augmented"
  for file in facts.txt facts.pdf facts-dark.pdf facts.epub qa.txt qa.pdf qa-dark.pdf qa.epub; do
    if [ -f "${dist_dir}/augmented/${file}" ]; then
      cp "${dist_dir}/augmented/${file}" "${out_dir}/augmented/${file}"
    fi
  done
fi

if [ -f "${dist_dir}/augmented/facts.txt" ]; then
  cp "${dist_dir}/augmented/facts.txt" "${out_dir}/amateur-extra-license-prep-augmented-facts.txt"
fi
if [ -f "${dist_dir}/augmented/facts.pdf" ]; then
  cp "${dist_dir}/augmented/facts.pdf" "${out_dir}/amateur-extra-license-prep-augmented-facts.pdf"
fi
if [ -f "${dist_dir}/augmented/facts-dark.pdf" ]; then
  cp "${dist_dir}/augmented/facts-dark.pdf" "${out_dir}/amateur-extra-license-prep-augmented-facts-dark.pdf"
fi
if [ -f "${dist_dir}/augmented/facts.epub" ]; then
  cp "${dist_dir}/augmented/facts.epub" "${out_dir}/amateur-extra-license-prep-augmented-facts.epub"
fi
if [ -f "${dist_dir}/augmented/qa.txt" ]; then
  cp "${dist_dir}/augmented/qa.txt" "${out_dir}/amateur-extra-license-prep-augmented-qa.txt"
fi
if [ -f "${dist_dir}/augmented/qa.pdf" ]; then
  cp "${dist_dir}/augmented/qa.pdf" "${out_dir}/amateur-extra-license-prep-augmented-qa.pdf"
fi
if [ -f "${dist_dir}/augmented/qa-dark.pdf" ]; then
  cp "${dist_dir}/augmented/qa-dark.pdf" "${out_dir}/amateur-extra-license-prep-augmented-qa-dark.pdf"
fi
if [ -f "${dist_dir}/augmented/qa.epub" ]; then
  cp "${dist_dir}/augmented/qa.epub" "${out_dir}/amateur-extra-license-prep-augmented-qa.epub"
fi

cp "${dist_dir}/audio/fact/script.txt" "${out_dir}/audio/fact/script.txt"
cp "${dist_dir}/audio/fact/manifest.json" "${out_dir}/audio/fact/manifest.json"
cp "${dist_dir}/audio/qa/script.txt" "${out_dir}/audio/qa/script.txt"
cp "${dist_dir}/audio/qa/manifest.json" "${out_dir}/audio/qa/manifest.json"
cp "${dist_dir}/audio/fact/script.txt" "${out_dir}/amateur-extra-license-prep-fact-script.txt"
cp "${dist_dir}/audio/fact/manifest.json" "${out_dir}/amateur-extra-license-prep-fact-manifest.json"
cp "${dist_dir}/audio/qa/script.txt" "${out_dir}/amateur-extra-license-prep-qa-script.txt"
cp "${dist_dir}/audio/qa/manifest.json" "${out_dir}/amateur-extra-license-prep-qa-manifest.json"

fact_audio_href="./amateur-extra-license-prep-fact.mp3"
fact_audio_desc="Merged fact audio book."
if [ -f "${dist_dir}/audio/fact/book.mp3" ]; then
  cp "${dist_dir}/audio/fact/book.mp3" "${out_dir}/audio/fact/book.mp3"
  cp "${dist_dir}/audio/fact/book.mp3" "${out_dir}/amateur-extra-license-prep-fact.mp3"
else
  fact_audio_href="./amateur-extra-license-prep-fact.mp3.placeholder.txt"
  fact_audio_desc="Placeholder until rendered chapter audio is merged."
  cat > "${out_dir}/audio/fact/book.mp3.placeholder.txt" <<'TEXT'
Placeholder for dist/audio/fact/book.mp3.
Run `mise run audio-render` to generate chapter audio and merged book audio.
TEXT
  cp "${out_dir}/audio/fact/book.mp3.placeholder.txt" "${out_dir}/amateur-extra-license-prep-fact.mp3.placeholder.txt"
fi

qa_audio_href="./amateur-extra-license-prep-qa.mp3"
qa_audio_desc="Merged Q&A audio book."
if [ -f "${dist_dir}/audio/qa/book.mp3" ]; then
  cp "${dist_dir}/audio/qa/book.mp3" "${out_dir}/audio/qa/book.mp3"
  cp "${dist_dir}/audio/qa/book.mp3" "${out_dir}/amateur-extra-license-prep-qa.mp3"
else
  qa_audio_href="./amateur-extra-license-prep-qa.mp3.placeholder.txt"
  qa_audio_desc="Placeholder until Q&A chapter audio is rendered and merged."
  cat > "${out_dir}/audio/qa/book.mp3.placeholder.txt" <<'TEXT'
Placeholder for dist/audio/qa/book.mp3.
Run `mise run audio-render` after generating/rendering Q&A chapter audio.
TEXT
  cp "${out_dir}/audio/qa/book.mp3.placeholder.txt" "${out_dir}/amateur-extra-license-prep-qa.mp3.placeholder.txt"
fi

has_augmented=false
if [ -d "${out_dir}/augmented" ]; then
  has_augmented=true
fi

augmented_note="No augmented artifacts available in this build."
if [ "${has_augmented}" = true ]; then
  augmented_note="Augmented artifacts include AI-generated prose in addition to the canonical answer."
fi

cat > "${out_dir}/index.html" <<HTML
<!doctype html>
