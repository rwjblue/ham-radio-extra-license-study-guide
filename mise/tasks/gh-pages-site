        </section>
        <section class="section">
          <h2>Q&A Facts</h2>
          <div class="assets">
            <a class="asset" href="./amateur-extra-license-prep-qa.pdf">
              <strong>qa.pdf</strong>
              <span>Printable Q&A workbook.</span>
            </a>
            <a class="asset" href="./amateur-extra-license-prep-qa-dark.pdf">
              <strong>qa-dark.pdf</strong>
              <span>Dark-theme Q&A workbook.</span>
            </a>
            <a class="asset" href="./amateur-extra-license-prep-qa.epub">
              <strong>qa.epub</strong>
              <span>E-reader version of Q&A output.</span>
