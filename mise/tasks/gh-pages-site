        --bg: #f6f9ff;
        --fg: #10243a;
        --muted: #4a5c71;
        --card: #ffffff;
        --border: #d7e1ef;
        --link: #0057b8;
      }
      body {
        margin: 0;
        font-family: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Palatino, serif;
        background: radial-gradient(circle at top right, #e7f0ff 0%, var(--bg) 55%);
        color: var(--fg);
      }
      main {
        max-width: 720px;
        margin: 40px auto;
        padding: 0 20px;
      }
      .card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 20px;
      }
      h1 {
        margin: 0 0 12px 0;
        font-size: clamp(1.6rem, 3vw, 2rem);
      }
      p {
        margin: 0 0 18px 0;
        color: var(--muted);
      }
      p:last-of-type {
        margin-top: 16px;
        margin-bottom: 0;
      }
      .pipeline {
        margin-top: 18px;
      }
      .assets {
        display: grid;
        gap: 10px;
        margin: 16px 0 0 0;
      }
      .section {
        margin-top: 22px;
      }
      .section h2 {
        font-size: 1.05rem;
        margin: 0;
      }
      .section p {
        margin: 8px 0 0 0;
      }
      .asset {
        display: block;
        text-decoration: none;
        border: 1px solid var(--border);
        border-radius: 10px;
