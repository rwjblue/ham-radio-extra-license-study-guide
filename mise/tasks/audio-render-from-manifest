#!/usr/bin/env bash
#MISE description="Render chapter text files from a provided manifest/out dir into audio"
#MISE depends=["deps-dev"]
set -euo pipefail

provider="${TTS_PROVIDER:-}"

cmd=(
  uv run extra-facts audio-render
  --manifest "${MANIFEST:-dist/audio/fact/manifest.json}"
  --out-dir "${OUT_DIR:-dist/audio/fact}"
  --elevenlabs-output-format "${ELEVENLABS_OUTPUT_FORMAT:-mp3_44100_128}"
  --elevenlabs-language-code "${ELEVENLABS_LANGUAGE_CODE:-en}"
  --speed "${SPEED:-1.0}"
  --jobs "${JOBS:-4}"
  --unit-cache-dir "${UNIT_CACHE_DIR:-.cache/audio-render}"
)

if [[ -n "${provider}" ]]; then
  cmd+=(--provider "${provider}")
fi
if [[ -n "${TTS_MODEL:-}" ]]; then
  cmd+=(--model "${TTS_MODEL}")
fi
if [[ -n "${TTS_VOICE:-}" ]]; then
  cmd+=(--voice "${TTS_VOICE}")
fi

if [[ -n "${INSTRUCTIONS:-}" ]]; then
  cmd+=(--instructions "${INSTRUCTIONS}")
fi
if [[ -n "${NO_MERGE:-}" ]]; then
  cmd+=(--no-merge)
fi
if [[ -n "${NO_CHAPTER_MARKERS:-}" ]]; then
  cmd+=(--no-chapter-markers)
fi
if [[ -n "${QC_OPENAI_TRANSCRIBE:-}" ]]; then
  qc_enabled="$(echo "${QC_OPENAI_TRANSCRIBE}" | tr '[:upper:]' '[:lower:]')"
  if [[ "${qc_enabled}" == "0" || "${qc_enabled}" == "false" || "${qc_enabled}" == "no" || "${qc_enabled}" == "off" ]]; then
    cmd+=(--no-qc-openai-transcribe)
  fi
fi
if [[ -n "${QC_OPENAI_MODEL:-}" ]]; then
  cmd+=(--qc-openai-model "${QC_OPENAI_MODEL}")
fi
if [[ -n "${QC_EXPECTED_LANGUAGE:-}" ]]; then
  cmd+=(--qc-expected-language "${QC_EXPECTED_LANGUAGE}")
fi
if [[ -n "${QC_MAX_WER:-}" ]]; then
  cmd+=(--qc-max-wer "${QC_MAX_WER}")
fi
if [[ -n "${QC_MAX_EXTRA_TOKENS:-}" ]]; then
  cmd+=(--qc-max-extra-tokens "${QC_MAX_EXTRA_TOKENS}")
fi
if [[ -n "${QC_MAX_ATTEMPTS:-}" ]]; then
  cmd+=(--qc-max-attempts "${QC_MAX_ATTEMPTS}")
fi
if [[ -n "${QC_LLM_JUDGE:-}" ]]; then
  qc_llm_enabled="$(echo "${QC_LLM_JUDGE}" | tr '[:upper:]' '[:lower:]')"
  if [[ "${qc_llm_enabled}" == "1" || "${qc_llm_enabled}" == "true" || "${qc_llm_enabled}" == "yes" || "${qc_llm_enabled}" == "on" ]]; then
    cmd+=(--qc-llm-judge)
  fi
fi
if [[ -n "${QC_LLM_MODEL:-}" ]]; then
  cmd+=(--qc-llm-model "${QC_LLM_MODEL}")
fi

"${cmd[@]}"
