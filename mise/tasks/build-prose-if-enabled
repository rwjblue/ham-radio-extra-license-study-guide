#!/usr/bin/env bash
#MISE description="Build prose outputs only when prose JSON exists"
#MISE depends=["prose-if-enabled"]
#MISE sources=["dist/extra_pool_prose.json", "src/**/*.py", "pyproject.toml"]
#MISE outputs={auto=true}
set -euo pipefail

if [ -z "${OPENAI_API_KEY:-}" ]; then
  echo "OPENAI_API_KEY not set; skipping prose build"
  exit 0
fi

if [ ! -f "${PROSE_JSON:-dist/extra_pool_prose.json}" ]; then
  echo "Prose JSON not found; skipping prose build"
  exit 0
fi

mise run build-prose
