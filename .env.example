# Copy to .env and set your key
OPENAI_API_KEY=your_openai_api_key_here
MODEL=gpt-5.1
PROMPT_VERSION=v1
OPENAI_HTTP_CACHE=1
OPENAI_HTTP_CACHE_DIR=.cache/openai-http

# Audio render provider (elevenlabs or openai)
TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
TTS_MODEL=eleven_multilingual_v2
TTS_VOICE=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_HTTP_CACHE=1
ELEVENLABS_HTTP_CACHE_DIR=.cache/elevenlabs-http
